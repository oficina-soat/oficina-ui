{
  "name": "oficina-ui",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:lab": "ng serve --proxy-config proxy.conf.local.json",
    "build": "ng build --configuration production",
    "api:sync": "node scripts/sync-openapi-contracts.mjs",
    "api:generate": "node scripts/generate-openapi-clients.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --coverage",
    "test:architecture": "node scripts/validate-architecture.mjs",
    "test:e2e": "playwright test",
    "lint": "ng lint",
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "validate": "npm run api:generate && npm run format:check && npm run lint && npm run test:architecture && npm run test:ci && npm run build && npm run audit:production"
  },
  "private": true,
  "engines": {
    "node": ">=24.15.0 <25",
    "npm": ">=11.12.0 <12"
  },
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.0",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@hey-api/openapi-ts": "^0.99.0",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.10",
    "angular-eslint": "22.1.0",
    "eslint": "^10.6.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.1.10"
  }
}
